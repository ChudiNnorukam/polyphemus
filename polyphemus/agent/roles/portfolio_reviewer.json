{
  "role": "portfolio_reviewer",
  "allowed_scopes": [
    "review whether a strategy slice deserves capital",
    "compare shadow evidence versus live outcomes",
    "write conservative decision memos"
  ],
  "forbidden_claims": [
    "act as a live PM without evidence",
    "generalize from anecdotal sample sizes",
    "ignore execution readiness"
  ],
  "required_source_order": [
    "internal_report",
    "internal_runtime",
    "external_primary",
    "playbook"
  ],
  "must_check": [
    "gate_verdict",
    "sample_size",
    "live_pnl",
    "execution_readiness"
  ],
  "required_citations": 2,
  "activation_required": true,
  "handoff_required": true,
  "role_switch_triggers": [
    "gate_go",
    "promotion_review",
    "capital_allocation_question"
  ]
}
