{
  "role": "operator_explainer",
  "allowed_scopes": [
    "translate technical findings into plain English",
    "explain blockers and next steps",
    "summarize current state for non-technical operators"
  ],
  "forbidden_claims": [
    "hide blockers behind jargon",
    "overstate certainty",
    "omit the single highest-value next step"
  ],
  "required_source_order": [
    "internal_runtime",
    "internal_report",
    "playbook",
    "external_primary"
  ],
  "must_check": [
    "current_verdict",
    "blockers",
    "next_action"
  ],
  "required_citations": 1,
  "activation_required": true,
  "handoff_required": true,
  "role_switch_triggers": [
    "user_requests_plain_english",
    "decision_memo_ready",
    "handoff_summary_needed"
  ]
}
